// Prisma schema for Maths4U Arena.
// This MVP foundation keeps flexible JSON text fields for future quiz modes.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  ADMIN
  TEACHER
}

enum TestStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTI_SELECT
  SHORT_TEXT
  NUMERIC
  TRUE_FALSE
  FILL_BLANK
  MATCHING
  ORDERING
  MANUAL_REVIEW
}

enum GradingType {
  EXACT
  ACCEPTED_ANSWERS
  KEYWORDS
  REGEX
  NUMERIC_TOLERANCE
  MANUAL
  FORMULA
}

enum GameMode {
  CLASSIC
  ACCURACY
  HOST_PACED
  TEAM
  PRACTICE
  CAROUSEL
}

enum GameSessionStatus {
  LOBBY
  RUNNING
  PAUSED
  FINISHED
}

enum StudentStatus {
  ACTIVE
  DISABLED
}

enum SeriesStatus {
  DRAFT
  REGISTRATION_OPEN
  ACTIVE
  FINISHED
  ARCHIVED
}

enum SeriesRegistrationStatus {
  REGISTERED
  REMOVED
}

enum SeriesRoundStatus {
  DRAFT
  SCHEDULED
  LOBBY
  RUNNING
  FINISHED
}

model User {
  id           String   @id @default(cuid()) @db.VarChar(191)
  email        String   @unique @db.VarChar(191)
  passwordHash String   @db.VarChar(255)
  name         String?  @db.VarChar(191)
  role         UserRole @default(TEACHER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tests Test[]
}

model Test {
  id          String     @id @default(cuid()) @db.VarChar(191)
  title       String     @db.VarChar(191)
  slug        String     @unique @db.VarChar(191)
  subject     String     @db.VarChar(191)
  description String?    @db.Text
  locale      String     @default("ru") @db.VarChar(16)
  status      TestStatus @default(DRAFT)
  createdById String?    @db.VarChar(191)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  createdBy User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  versions  TestVersion[]

  @@index([createdById])
  @@index([status])
  @@index([subject])
}

model TestVersion {
  id            String     @id @default(cuid()) @db.VarChar(191)
  testId        String     @db.VarChar(191)
  versionNumber Int
  title         String     @db.VarChar(191)
  instructions  String?    @db.LongText
  settingsJson  String?    @db.LongText
  status        TestStatus @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  test      Test                  @relation(fields: [testId], references: [id], onDelete: Cascade)
  questions TestVersionQuestion[]
  sessions  GameSession[]
  seriesRounds SeriesRound[]

  @@unique([testId, versionNumber])
  @@index([status])
}

model Question {
  id               String       @id @default(cuid()) @db.VarChar(191)
  subject          String       @db.VarChar(191)
  type             QuestionType
  prompt           String       @db.LongText
  explanation      String?      @db.LongText
  difficulty       Int          @default(1)
  tagsJson         String?      @db.LongText
  mediaJson        String?      @db.LongText
  gradingType      GradingType
  gradingRulesJson String?      @db.LongText
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  options      QuestionOption[]
  testVersions TestVersionQuestion[]
  answers      Answer[]
  scoreEvents  ScoreEvent[]

  @@index([subject])
  @@index([type])
  @@index([difficulty])
}

model QuestionOption {
  id         String  @id @default(cuid()) @db.VarChar(191)
  questionId String  @db.VarChar(191)
  optionText String  @db.LongText
  isCorrect  Boolean @default(false)
  sortOrder  Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
}

model TestVersionQuestion {
  id               String  @id @default(cuid()) @db.VarChar(191)
  testVersionId    String  @db.VarChar(191)
  questionId       String  @db.VarChar(191)
  sortOrder        Int
  points           Int     @default(1)
  timeLimitSeconds Int?
  settingsJson     String? @db.LongText

  testVersion TestVersion @relation(fields: [testVersionId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([testVersionId, questionId])
  @@index([questionId])
}

model GameSession {
  id            String            @id @default(cuid()) @db.VarChar(191)
  testVersionId String            @db.VarChar(191)
  code          String            @unique @db.VarChar(16)
  mode          GameMode          @default(CLASSIC)
  status        GameSessionStatus @default(LOBBY)
  settingsJson  String?           @db.LongText
  showResults   Boolean           @default(true)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  testVersion  TestVersion   @relation(fields: [testVersionId], references: [id], onDelete: Restrict)
  participants Participant[]
  answers      Answer[]
  scoreEvents  ScoreEvent[]
  seriesRounds SeriesRound[]
  seriesScores SeriesScore[]

  @@index([testVersionId])
  @@index([status])
}

model Participant {
  id          String   @id @default(cuid()) @db.VarChar(191)
  sessionId   String   @db.VarChar(191)
  studentAccountId String? @db.VarChar(191)
  displayName String   @db.VarChar(191)
  tokenHash   String   @db.VarChar(255)
  teamId      String?  @db.VarChar(191)
  joinedAt    DateTime @default(now())

  session        GameSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentAccount StudentAccount? @relation(fields: [studentAccountId], references: [id], onDelete: SetNull)
  answers        Answer[]
  scoreEvents    ScoreEvent[]

  @@index([sessionId])
  @@index([studentAccountId])
  @@index([teamId])
}

model Answer {
  id            String   @id @default(cuid()) @db.VarChar(191)
  sessionId     String   @db.VarChar(191)
  participantId String   @db.VarChar(191)
  questionId    String   @db.VarChar(191)
  answerJson    String   @db.LongText
  isCorrect     Boolean?
  points        Int      @default(0)
  responseMs    Int?
  submittedAt   DateTime @default(now())

  session     GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  question    Question    @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@index([sessionId])
  @@index([participantId])
  @@index([questionId])
}

model ScoreEvent {
  id            String   @id @default(cuid()) @db.VarChar(191)
  sessionId     String   @db.VarChar(191)
  participantId String?  @db.VarChar(191)
  questionId    String?  @db.VarChar(191)
  eventType     String   @db.VarChar(64)
  pointsDelta   Int      @default(0)
  metaJson      String?  @db.LongText
  createdAt     DateTime @default(now())

  session     GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  question    Question?    @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([participantId])
  @@index([questionId])
  @@index([eventType])
}

model StudentAccount {
  id           String        @id @default(cuid()) @db.VarChar(191)
  username     String        @unique @db.VarChar(191)
  displayName  String        @db.VarChar(191)
  passwordHash String        @db.VarChar(255)
  groupName    String?       @db.VarChar(191)
  status       StudentStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  registrations SeriesRegistration[]
  participants  Participant[]
  scores        SeriesScore[]

  @@index([status])
  @@index([groupName])
}

model Series {
  id           String       @id @default(cuid()) @db.VarChar(191)
  title        String       @db.VarChar(191)
  description  String?      @db.LongText
  status       SeriesStatus @default(DRAFT)
  startsAt     DateTime?
  endsAt       DateTime?
  settingsJson String?      @db.LongText
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  registrations SeriesRegistration[]
  rounds        SeriesRound[]
  scores        SeriesScore[]

  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
}

model SeriesRegistration {
  id                  String                   @id @default(cuid()) @db.VarChar(191)
  seriesId            String                   @db.VarChar(191)
  studentId           String                   @db.VarChar(191)
  displayNameSnapshot String                   @db.VarChar(191)
  status              SeriesRegistrationStatus @default(REGISTERED)
  createdAt           DateTime                 @default(now())

  series  Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([seriesId, studentId])
  @@index([studentId])
  @@index([status])
}

model SeriesRound {
  id            String            @id @default(cuid()) @db.VarChar(191)
  seriesId      String            @db.VarChar(191)
  testVersionId String            @db.VarChar(191)
  title         String            @db.VarChar(191)
  roundNumber   Int
  scheduledAt   DateTime?
  status        SeriesRoundStatus @default(DRAFT)
  sessionId     String?           @db.VarChar(191)
  settingsJson  String?           @db.LongText
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  series      Series       @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  testVersion TestVersion  @relation(fields: [testVersionId], references: [id], onDelete: Restrict)
  session     GameSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  scores      SeriesScore[]

  @@unique([seriesId, roundNumber])
  @@index([testVersionId])
  @@index([sessionId])
  @@index([status])
  @@index([scheduledAt])
}

model SeriesScore {
  id            String   @id @default(cuid()) @db.VarChar(191)
  seriesId      String   @db.VarChar(191)
  studentId     String   @db.VarChar(191)
  roundId       String?  @db.VarChar(191)
  sessionId     String?  @db.VarChar(191)
  points        Int      @default(0)
  correctCount  Int      @default(0)
  answeredCount Int      @default(0)
  percentage    Float    @default(0)
  rank          Int?
  metaJson      String?  @db.LongText
  createdAt     DateTime @default(now())

  series  Series         @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  student StudentAccount @relation(fields: [studentId], references: [id], onDelete: Cascade)
  round   SeriesRound?   @relation(fields: [roundId], references: [id], onDelete: SetNull)
  session GameSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([seriesId])
  @@index([studentId])
  @@index([roundId])
  @@index([sessionId])
  @@index([rank])
}
